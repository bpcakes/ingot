{
  "name": "ui",
  "private": true,
  "version": "0.0.0",
  "description": "Desktop shell for Ingot.",
  "author": "Ingot contributors",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "electron:dev": "node electron/dev.cjs",
    "electron:test": "node --test electron/*.test.cjs && node --check electron/main.cjs && node --check electron/preload.cjs && node --check electron/dev.cjs && node --check electron/daemon-url.cjs && node --check electron/daemon-url.test.cjs",
    "electron:build": "bun run build && cargo build --release --bin ingotd --manifest-path ../Cargo.toml && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "electron:dist": "bun run build && cargo build --release --bin ingotd --manifest-path ../Cargo.toml && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.66.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.13.1",
    "shadcn": "^4.0.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "dev.ingot.desktop",
    "productName": "Ingot",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json",
      "!node_modules/**"
    ],
    "extraResources": [
      {
        "from": "../target/release/ingotd",
        "to": "bin/ingotd"
      }
    ],
    "mac": {
      "target": [
        "dir"
      ]
    },
    "linux": {
      "target": [
        "dir"
      ]
    }
  }
}
